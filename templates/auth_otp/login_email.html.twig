{% extends 'base.html.twig' %}

{% block body %}
  <style>
    .auth-page {
      min-height: 100vh;
      background: #f1f5f9;
    }

    .auth-split {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 58% 42%;
    }

    .auth-visual {
      min-height: 100vh;
      background:
        linear-gradient(rgba(15, 23, 42, 0.12), rgba(15, 23, 42, 0.12)),
        url('{{ asset('images/nathan-mullet-7bRNqEVb6Zg-unsplash.jpg') }}') center center / cover no-repeat;
    }

    .auth-form-side {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem;
      background: #f8fafc;
    }

    .auth-card {
      width: 100%;
      max-width: 480px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 28px;
      padding: 2.5rem;
      box-shadow: 0 30px 70px -45px rgba(15, 23, 42, 0.35);
    }

    .auth-kicker {
      margin: 0;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: #1d4ed8;
    }

    .auth-title {
      margin: 0.85rem 0 0;
      font-size: 3rem;
      line-height: 1.05;
      font-weight: 700;
      color: #0f172a;
    }

    .auth-subtitle {
      margin: 0.9rem 0 0;
      font-size: 1rem;
      line-height: 1.6;
      color: #64748b;
    }

    .auth-alert {
      margin-top: 1rem;
      border-radius: 18px;
      padding: 0.9rem 1rem;
      font-size: 0.95rem;
      border: 1px solid;
    }

    .auth-alert-error {
      border-color: #fecdd3;
      background: #fff1f2;
      color: #be123c;
    }

    .auth-alert-success {
      border-color: #a7f3d0;
      background: #ecfdf5;
      color: #047857;
    }

    .auth-form {
      margin-top: 2rem;
    }

    .auth-label {
      display: block;
      margin-bottom: 0.55rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: #334155;
    }

    .auth-input-wrap {
      position: relative;
    }

    .auth-input {
      width: 100%;
      height: 3.9rem;
      border-radius: 20px;
      border: 1px solid #cbd5e1;
      background: #f8fafc;
      padding: 0 3.75rem 0 1.2rem;
      font-size: 1rem;
      color: #0f172a;
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .auth-input:focus {
      border-color: #1d4ed8;
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(29, 78, 216, 0.12);
    }

    .auth-input-suffix {
      position: absolute;
      top: 50%;
      right: 1.2rem;
      transform: translateY(-50%);
      color: #94a3b8;
      font-size: 1.35rem;
      pointer-events: none;
    }

    .auth-button {
      width: 100%;
      height: 3.6rem;
      margin-top: 1.4rem;
      border: 0;
      border-radius: 20px;
      background: #1d4ed8;
      color: #ffffff;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 18px 34px -22px rgba(29, 78, 216, 0.65);
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .auth-button:hover {
      background: #1e40af;
      transform: translateY(-1px);
    }

    @media (max-width: 980px) {
      .auth-split {
        grid-template-columns: 1fr;
      }

      .auth-visual {
        min-height: 34vh;
      }

      .auth-form-side {
        min-height: auto;
        padding: 1.5rem;
      }

      .auth-card {
        max-width: 100%;
        margin-top: -4rem;
        position: relative;
      }
    }
  </style>

  <div class="auth-page">
    <div class="auth-split">
      <section class="auth-visual" aria-hidden="true"></section>

      <section class="auth-form-side">
        <div class="auth-card">
          <p class="auth-kicker">Connexion</p>
          <h1 class="auth-title">Acceder a votre espace</h1>
          <p class="auth-subtitle">Saisissez votre adresse email pour recevoir votre code.</p>

          {% for message in app.flashes('error') %}
            <div class="auth-alert auth-alert-error">{{ message }}</div>
          {% endfor %}
          {% for message in app.flashes('success') %}
            <div class="auth-alert auth-alert-success">{{ message }}</div>
          {% endfor %}

          <form method="post" action="{{ path('app_login_email') }}" class="auth-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('login_email') }}">

            <label for="email" class="auth-label">Adresse email</label>
            <div class="auth-input-wrap">
              <input
                id="email"
                class="auth-input"
                type="email"
                name="email"
                required
                autofocus
                autocomplete="email"
                placeholder="vous@entreprise.com"
              >
              <span class="auth-input-suffix">@</span>
            </div>

            <button type="submit" class="auth-button">Recevoir mon code</button>
          </form>
        </div>
      </section>
    </div>
  </div>
{% endblock %}
