{% extends 'base.html.twig' %}

{% block body %}
  <div class="min-h-screen flex items-center justify-center bg-slate-100 px-6">
    <div class="w-full max-w-lg rounded-[28px] border border-slate-200 bg-white p-10 text-center shadow-[0_30px_70px_-45px_rgba(15,23,42,0.35)]">
      <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[#1d4ed8]">IntraPo</p>
      <h1 class="mt-4 text-3xl font-semibold text-slate-900">Aucun module disponible</h1>
      <p class="mt-3 text-base leading-7 text-slate-600">
        Aucun module n'est accessible pour votre compte actuellement.
      </p>

      <form method="post" action="{{ path('app_logout') }}" class="mt-8">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout_post') }}">
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-2xl bg-[#1d4ed8] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#1e40af]"
        >
          Se deconnecter
        </button>
      </form>
    </div>
  </div>
{% endblock %}
