{% extends 'base.html.twig' %}

{% block title %}Accueil | Intranet PO{% endblock %}

{% block body %}
  <style>
    .home-shell {
      min-height: 100vh;
      padding: 2rem 1rem 3rem;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 32%),
        radial-gradient(circle at right top, rgba(56, 189, 248, 0.12), transparent 24%),
        #f8fafc;
    }

    .home-wrap {
      max-width: 1200px;
      margin: 0 auto;
    }

    .home-topbar,
    .home-panel,
    .section-card {
      border: 1px solid rgba(148, 163, 184, 0.22);
      background: rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(12px);
      box-shadow: 0 28px 70px -50px rgba(15, 23, 42, 0.3);
    }

    .home-topbar {
      border-radius: 24px;
      padding: 1rem 1.2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .home-brand {
      display: flex;
      align-items: center;
      gap: 0.85rem;
    }

    .home-brand img {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 0.9rem;
    }

    .home-brand-title {
      margin: 0;
      font-size: 1.65rem;
      font-weight: 700;
      color: #1e293b;
    }

    .home-brand-subtitle {
      margin: 0.15rem 0 0;
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #64748b;
    }

    .home-user {
      border: 1px solid rgba(99, 102, 241, 0.2);
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font-size: 0.9rem;
      color: #334155;
      background: rgba(239, 246, 255, 0.8);
    }

    .home-panel {
      margin-top: 1.2rem;
      border-radius: 28px;
      padding: 1.5rem;
    }

    .home-panel-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }

    .home-title {
      margin: 0;
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
    }

    .home-subtitle {
      margin: 0.45rem 0 0;
      max-width: 48rem;
      font-size: 1rem;
      line-height: 1.7;
      color: #64748b;
    }

    .home-pill {
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font-weight: 700;
      color: #1d4ed8;
      background: rgba(219, 234, 254, 0.8);
      border: 1px solid rgba(59, 130, 246, 0.22);
      white-space: nowrap;
    }

    .sections-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .section-card {
      border-radius: 24px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      min-height: 260px;
    }

    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .section-icon {
      width: 3rem;
      height: 3rem;
      border-radius: 1rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #1d4ed8;
      background: rgba(219, 234, 254, 0.9);
      border: 1px solid rgba(59, 130, 246, 0.16);
    }

    .section-badge {
      width: 0.8rem;
      height: 0.8rem;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 6px rgba(34, 197, 94, 0.14);
    }

    .section-title {
      margin: 0;
      font-size: 1.35rem;
      font-weight: 700;
      color: #1e293b;
    }

    .section-description {
      margin: 0.45rem 0 0;
      font-size: 0.95rem;
      line-height: 1.65;
      color: #64748b;
    }

    .section-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .section-link-chip {
      border-radius: 999px;
      padding: 0.38rem 0.72rem;
      font-size: 0.82rem;
      color: #46608f;
      border: 1px solid rgba(148, 163, 184, 0.24);
      background: rgba(248, 250, 252, 0.96);
    }

    .section-footer {
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px dashed rgba(99, 102, 241, 0.18);
      display: flex;
      justify-content: flex-end;
    }

    .section-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 0.65rem 1rem;
      font-weight: 700;
      color: #ffffff;
      background: linear-gradient(135deg, #3257f6, #4b6fff);
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .sections-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .home-shell {
        padding: 1rem 0.7rem 2rem;
      }

      .sections-grid {
        grid-template-columns: 1fr;
      }

      .home-topbar,
      .home-panel,
      .section-card {
        border-radius: 20px;
      }
    }
  </style>

  <div class="home-shell">
    <div class="home-wrap">
      <div class="home-topbar">
        <div class="home-brand">
          <img src="{{ asset('images/logo.png') }}" alt="IntraPo">
          <div>
            <p class="home-brand-title">IntraPo Workspace</p>
            <p class="home-brand-subtitle">Administration</p>
          </div>
        </div>
        <div class="home-user">Profil: {{ app.user ? app.user.userIdentifier : '' }}</div>
      </div>

      <section class="home-panel">
        <div class="home-panel-head">
          <div>
            <h1 class="home-title">Sections du menu</h1>
            <p class="home-subtitle">
              Acces direct aux principales sections de l'administration.
            </p>
          </div>
          <div class="home-pill">{{ menuSections|length }} section{{ menuSections|length > 1 ? 's' : '' }}</div>
        </div>

        <div class="sections-grid">
          {% for section in menuSections %}
            <article class="section-card">
              <div class="section-head">
                <span class="section-icon">
                  <i data-lucide="{{ section.icon }}" class="w-6 h-6"></i>
                </span>
                <span class="section-badge"></span>
              </div>

              <div>
                <h2 class="section-title">{{ section.title }}</h2>
                <p class="section-description">{{ section.description }}</p>
              </div>

              <div class="section-links">
                {% for link in section.links %}
                  <span class="section-link-chip">{{ link.label }}</span>
                {% endfor %}
              </div>

              <div class="section-footer">
                <a href="{{ path(section.links[0].route) }}" class="section-link">Ouvrir</a>
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      window.setTimeout(() => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      }, 0);
    });
  </script>
{% endblock %}
