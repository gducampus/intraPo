<div class="space-y-4">
  {% for folder in folders %}
    <div class="rounded-xl border border-border/60 bg-panel p-4">
      <div class="flex items-start justify-between gap-2">
        <div>
          <div class="flex items-center gap-2 flex-wrap">
            <p class="text-sm font-semibold text-text">{{ folder.name }}</p>
            {% if folder.isSecured %}
              <span class="badge badge-warning">Securise</span>
            {% endif %}
          </div>
          {% if folder.description %}
            <p class="text-xs text-muted mt-1">{{ folder.description }}</p>
          {% endif %}
        </div>
      </div>

      {% if folder.items is not empty %}
        <div class="mt-4 space-y-2">
          {% for item in folder.items %}
            <div class="rounded-lg border border-border/60 bg-panel-2 px-3 py-2 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm text-text font-medium truncate">{{ item.title }}</p>
                {% if item.description %}
                  <p class="text-xs text-muted mt-0.5">{{ item.description }}</p>
                {% endif %}
              </div>

              {% if item.itemType == constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') %}
                <a href="{{ path('app_document_file_download', {'id': item.id}) }}" class="text-xs font-medium text-indigo-400 hover:text-indigo-300 shrink-0">
                  Ouvrir le fichier
                </a>
              {% else %}
                <a href="{{ item.externalUrl }}" target="_blank" rel="noopener" class="text-xs font-medium text-indigo-400 hover:text-indigo-300 shrink-0">
                  Ouvrir le lien
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% set visibleChildren = folder.children|filter(child => documentAccessManager.canAccessFolder(app.user, child)) %}
      {% if visibleChildren is not empty %}
        <div class="mt-4 border-l border-border/60 pl-3 md:pl-5">
          {{ include('document/_folder_tree.html.twig', {folders: visibleChildren}) }}
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>
