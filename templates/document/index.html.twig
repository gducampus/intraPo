{% extends 'module/base.html.twig' %}

{% block title %}Bibliotheque documentaire - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Documents</p>
    <h1 class="text-sm font-semibold text-text">Bibliotheque documentaire</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="mb-8 flex items-center justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-2">Dossiers et fichiers</h1>
      <p class="text-muted">Accedez aux contenus selon vos droits: videos, fichiers PDF/images et liens externes.</p>
    </div>
    <a href="{{ path('app_home') }}" class="btn btn-secondary">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      <span>Retour aux modules</span>
    </a>
  </div>

  <div class="card-elevated p-6">
    {% if roots is empty %}
      <div class="py-12 text-center text-muted">
        Aucun dossier disponible pour votre profil.
      </div>
    {% else %}
      {{ include('document/_folder_tree.html.twig', {folders: roots}) }}
    {% endif %}
  </div>
{% endblock %}
