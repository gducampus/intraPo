<!doctype html>
<html lang="fr" class="dark">
<head>
  <script>
    if (localStorage.getItem("theme") === "light") document.documentElement.classList.remove("dark");
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{% block title %}Administration â€” Intranet PO{% endblock %}</title>
  <link rel="icon" href="{{ asset('images/logo.png') }}" />
  <link href="{{ asset('css/index.css') }}" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet">
  <style>
    .inner-content {
      padding-bottom: 2.25rem;
    }

    .card-elevated {
      border: 0.8px solid rgba(148, 163, 184, 0.14);
      border-radius: 1.05rem;
      box-shadow:
        0 16px 40px -30px rgba(15, 23, 42, 0.65),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
      overflow: hidden;
    }

    .card-elevated.p-8,
    .card-elevated.p-6 {
      overflow: visible;
    }

    .card-elevated form .rounded-xl.border {
      background: rgba(148, 163, 184, 0.08);
      border-color: rgba(148, 163, 184, 0.18);
    }

    .data-table thead th {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: #94a3b8;
      padding-top: 0.95rem;
      padding-bottom: 0.95rem;
    }

    .data-table tbody td {
      padding-top: 0.95rem;
      padding-bottom: 0.95rem;
      vertical-align: top;
    }

    .data-table tbody tr:hover {
      background: var(--color-panel) !important;
    }

    .data-table tbody tr:hover td {
      background: transparent !important;
    }

    .admin-table {
      border-spacing: 0 4px;
      table-layout: auto;
    }

    .admin-table thead th {
      padding: 0.62rem 0.72rem;
      font-size: 0.64rem;
      letter-spacing: 0.08em;
      border-bottom-color: rgba(148, 163, 184, 0.2);
      white-space: normal;
    }

    .admin-table tbody td {
      padding: 0.62rem 0.72rem;
      line-height: 1.35;
      white-space: normal;
      word-break: break-word;
    }

    .admin-table tbody td:first-child,
    .admin-table tbody td:last-child {
      border-radius: 10px;
    }

    .admin-table .badge {
      font-size: 0.64rem;
      line-height: 1.2;
      padding: 0.21rem 0.45rem;
    }

    .admin-table .btn,
    .admin-table button,
    .admin-table a {
      line-height: 1.2;
    }

    .admin-table td:last-child {
      white-space: nowrap;
    }

    @media (max-width: 768px) {
      .admin-table {
        border-spacing: 0 2px;
      }

      .admin-table thead th {
        padding: 0.52rem 0.55rem;
      }

      .admin-table tbody td {
        padding: 0.5rem 0.55rem;
      }
    }

    .form-control {
      min-height: 2.85rem;
      border-radius: 0.8rem;
      padding-left: 0.82rem;
      padding-right: 0.82rem;
    }

    textarea.form-control {
      min-height: 7.2rem;
      padding-top: 0.72rem;
      padding-bottom: 0.72rem;
      line-height: 1.45;
    }

    .btn {
      border-radius: 0.8rem;
      min-height: 2.15rem;
      font-size: 0.78rem;
      padding: 0.45rem 0.72rem;
      gap: 0.32rem;
    }

    .btn-icon {
      width: 2.05rem;
      height: 2.05rem;
    }

    .select2-container {
      width: 100% !important;
    }

    .select2-container--default .select2-selection--multiple {
      min-height: 2.85rem;
      border-radius: 0.8rem;
      border: 1px solid rgba(148, 163, 184, 0.45);
      background: #f8fafc;
      padding: 0.32rem 0.38rem;
    }

    .select2-container--default.select2-container--focus .select2-selection--multiple {
      border-color: rgba(100, 116, 139, 0.7);
      box-shadow: 0 0 0 2px rgba(148, 163, 184, 0.24);
    }

    .select2-container--default .select2-selection--multiple .select2-selection__choice {
      border: 1px solid rgba(148, 163, 184, 0.48);
      background: #e2e8f0;
      color: #334155;
      border-radius: 0.55rem;
      font-size: 0.72rem;
      padding: 0.14rem 0.5rem;
      margin-top: 0.2rem;
    }

    .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
      color: #64748b;
      margin-right: 0.28rem;
    }

    .select2-container--default .select2-search--inline .select2-search__field {
      color: #0f172a;
      margin-top: 0.2rem;
    }

    .select2-container--default .select2-selection--multiple .select2-selection__placeholder {
      color: #64748b;
    }

    .select2-dropdown {
      border: 1px solid rgba(148, 163, 184, 0.45);
      border-radius: 0.7rem;
      background: #ffffff;
      color: #0f172a;
    }

    .select2-results__option {
      font-size: 0.78rem;
    }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
      background: #eef2f7;
      color: #0f172a;
    }

    .dark .select2-container--default .select2-selection--multiple {
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.55);
    }

    .dark .select2-container--default .select2-selection--multiple .select2-selection__choice {
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: rgba(51, 65, 85, 0.8);
      color: #e2e8f0;
    }

    .dark .select2-container--default .select2-search--inline .select2-search__field {
      color: #e2e8f0;
    }

    .dark .select2-dropdown {
      background: #111827;
      color: #e5e7eb;
      border-color: rgba(148, 163, 184, 0.35);
    }

    .dark .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
      background: rgba(71, 85, 105, 0.75);
      color: #fff;
    }
  </style>
</head>
<body id="dashboard">

  {# â”€â”€ Sidebar overlay (mobile) â”€â”€ #}
  <div id="sidebarOverlay"
       class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity duration-300 opacity-0"
       aria-hidden="true"></div>

  {# â”€â”€ Sidebar â”€â”€ #}
  <aside class="sidebar" id="sidebar">
    {{ include('admin/_sidebar.html.twig') }}
  </aside>

  {# â”€â”€ Contenu principal â”€â”€ #}
  <main class="main-content" id="mainContent">

    {# â”€â”€ Header â”€â”€ #}
    <header class="sticky top-0 z-50 glass">
      <div class="flex items-center justify-between px-2 sm:px-6 py-2 sm:py-4">

        <div class="flex items-center gap-4">
          <button class="mobile-menu-btn js-mobile-menu-toggle"
                  id="mobileMenuBtn"
                  aria-label="Ouvrir le menu">
            <i data-lucide="menu" class="w-5 h-5"></i>
          </button>
          <button class="sidebar-toggle-btn js-sidebar-toggle"
                  aria-label="RÃ©duire la sidebar">
            <i data-lucide="panel-left" class="w-5 h-5"></i>
          </button>
          <div>{% block page_header %}{% endblock %}</div>
        </div>

        <div class="flex items-center gap-2 sm:gap-3">
          {# Toggle thÃ¨me #}
          <button class="btn-icon" id="themeToggle" aria-label="ThÃ¨me clair/sombre"
                  onclick="document.documentElement.classList.toggle('dark');
                           localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');">
            <i data-lucide="moon" class="w-5 h-5 dark:hidden"></i>
            <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
          </button>
          <span class="hidden text-sm text-muted lg:block">{{ app.user ? app.user.userIdentifier : '' }}</span>
          <form method="post" action="{{ path('app_logout') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout_post') }}">
            <button type="submit"
                    class="btn-icon"
                    style="color: var(--color-red-400, #f87171);"
                    aria-label="Deconnexion">
              <i data-lucide="log-out" class="w-5 h-5"></i>
            </button>
          </form>
        </div>

      </div>
    </header>

    {# â”€â”€ Contenu de la page â”€â”€ #}
    <div class="inner-content">

      {% for message in app.flashes('error') %}
        <div class="mb-6 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-400">{{ message }}</div>
      {% endfor %}
      {% for message in app.flashes('success') %}
        <div class="mb-6 rounded-xl border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-400">{{ message }}</div>
      {% endfor %}

      {% block content %}{% endblock %}

    </div>

  </main>

  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <script>
    function initAdminSelect2() {
      if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
        return;
      }

      window.jQuery('.js-select2').each(function () {
        const $el = window.jQuery(this);
        if ($el.hasClass('select2-hidden-accessible')) {
          return;
        }

        $el.select2({
          width: '100%',
          closeOnSelect: false,
          placeholder: $el.data('placeholder') || 'Selectionner',
        });
      });
    }

    document.addEventListener('DOMContentLoaded', initAdminSelect2);
    document.addEventListener('turbo:load', initAdminSelect2);
  </script>
  <script>
    function collapseAdminSubmenus() {
      window.setTimeout(() => {
        document.querySelectorAll('.submenu').forEach((submenu) => {
          submenu.classList.remove('open');
        });

        document.querySelectorAll('.js-submenu-toggle').forEach((toggle) => {
          toggle.classList.remove('expanded');
        });
      }, 0);
    }

    document.addEventListener('DOMContentLoaded', collapseAdminSubmenus);
    document.addEventListener('turbo:load', collapseAdminSubmenus);
  </script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js" defer></script>
  <script defer src="{{ asset('js/index.js') }}"></script>

</body>
</html>

