{% extends 'admin/base.html.twig' %}

{% block title %}New member — Administration — Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">New member</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_member_index') }}" class="hover:text-text transition">Members</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">New member</span>
  </div>

  <div class="max-w-5xl">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Create member</h2>
      <p class="text-sm text-muted mb-8">Saisissez les informations du membre.</p>
      {{ include('admin/member/_form.html.twig', {'button_label': 'Create member'}) }}
    </div>
  </div>
{% endblock %}

