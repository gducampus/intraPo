{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ user.email }} — Administration — Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Modifier un compte utilisateur</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_po_user_index') }}" class="hover:text-text transition">Comptes utilisateurs</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">{{ user.email }}</span>
  </div>

  <div class="max-w-3xl space-y-6">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Informations du compte</h2>
      <p class="text-sm text-muted mb-8">
        Mettre a jour le nom, l'email et les roles du compte.
      </p>
      {{ include('admin/po_user/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
    </div>

    {% if not (app.user and app.user.userIdentifier == user.email) %}
      <div class="card-elevated p-6" style="border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.04);">
        <h3 class="text-sm font-semibold text-red-400">Zone dangereuse</h3>
        <p class="mt-1 text-sm text-muted">La suppression est irreversible.</p>
        <div class="mt-4">
          {{ include('admin/po_user/_delete_form.html.twig') }}
        </div>
      </div>
    {% endif %}
  </div>
{% endblock %}
