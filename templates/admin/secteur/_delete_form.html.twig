<form method="post" action="{{ path('app_secteur_delete', {'id': secteur.id}) }}"
      onsubmit="return confirm('Supprimer définitivement ce secteur ?');">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ secteur.id) }}">
  <button type="submit" class="btn" style="background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3);">
    <i data-lucide="trash-2" class="w-4 h-4"></i>
    Supprimer ce secteur
  </button>
</form>
