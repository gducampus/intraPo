{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ secteur.name }} — Administration — Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Modifier un secteur</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_secteur_index') }}" class="hover:text-text transition">Secteurs</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">{{ secteur.name }}</span>
  </div>

  <div class="max-w-lg space-y-6">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Modifier le secteur</h2>
      <p class="text-sm text-muted mb-8">
        Modifiez le nom de <span class="font-medium text-text">{{ secteur.name }}</span>.
      </p>
      {{ include('admin/secteur/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
    </div>

    <div class="card-elevated p-6" style="border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.04);">
      <h3 class="text-sm font-semibold text-red-400">Zone dangereuse</h3>
      <p class="mt-1 text-sm text-muted">La suppression est irréversible.</p>
      <div class="mt-4">
        {{ include('admin/secteur/_delete_form.html.twig') }}
      </div>
    </div>
  </div>
{% endblock %}
