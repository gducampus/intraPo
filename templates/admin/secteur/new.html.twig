{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau secteur — Administration — Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Nouveau secteur</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_secteur_index') }}" class="hover:text-text transition">Secteurs</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">Nouveau</span>
  </div>

  <div class="max-w-lg">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Créer un secteur</h2>
      <p class="text-sm text-muted mb-8">Renseignez le nom du nouveau secteur.</p>
      {{ include('admin/secteur/_form.html.twig') }}
    </div>
  </div>
{% endblock %}
