{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

  <div class="rounded-xl border border-border/60 p-5">
    <h3 class="text-sm font-semibold text-text mb-4">Definition du role</h3>
    <div class="grid gap-6 lg:grid-cols-2">
      <div>
        {{ form_label(form.label, 'Nom', {'label_attr': {'class': 'block text-sm font-medium text-text mb-1.5'}}) }}
        {{ form_widget(form.label, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Acces RH'}}) }}
        {{ form_errors(form.label) }}
      </div>
      <div>
        {{ form_label(form.code, 'Code role', {'label_attr': {'class': 'block text-sm font-medium text-text mb-1.5'}}) }}
        {{ form_widget(form.code, {'attr': {'class': 'form-control font-mono text-xs'}}) }}
        <p class="mt-1 text-xs text-muted">{{ form_help(form.code) }}</p>
        {{ form_errors(form.code) }}
      </div>
    </div>
  </div>

  <div class="rounded-xl border border-border/60 p-5">
    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-sm font-medium text-text mb-1.5'}}) }}
    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Usage metier du role'}}) }}
    {{ form_errors(form.description) }}
  </div>

  <div class="flex items-center gap-4 pt-1">
    <button type="submit" class="btn btn-primary">
      {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_role_index') }}" class="text-sm text-muted hover:text-text transition">Annuler</a>
  </div>

{{ form_end(form) }}

