{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ role.code }} - Administration - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Modifier un role</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_role_index') }}" class="hover:text-text transition">Roles</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">{{ role.code }}</span>
  </div>

  <div class="max-w-3xl space-y-6">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Edition du role</h2>
      <p class="text-sm text-muted mb-8">Le code du role est propage aux comptes si vous le modifiez.</p>
      {{ include('admin/role/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
    </div>

    {% if not isProtected %}
      <div class="card-elevated p-6" style="border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.04);">
        <h3 class="text-sm font-semibold text-red-400">Zone dangereuse</h3>
        <p class="mt-1 text-sm text-muted">Suppression possible uniquement si aucun compte n'utilise ce role.</p>
        <div class="mt-4">
          {{ include('admin/role/_delete_form.html.twig') }}
        </div>
      </div>
    {% endif %}
  </div>
{% endblock %}

