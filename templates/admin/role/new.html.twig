{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau role - Administration - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Nouveau role</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex items-center gap-2 text-sm text-muted mb-8">
    <a href="{{ path('app_role_index') }}" class="hover:text-text transition">Roles</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-text">Nouveau</span>
  </div>

  <div class="max-w-3xl">
    <div class="card-elevated p-8">
      <h2 class="text-lg font-semibold text-text mb-1">Creer un role</h2>
      <p class="text-sm text-muted mb-8">Definir un role reutilisable dans la gestion des comptes.</p>
      {{ include('admin/role/_form.html.twig', {'button_label': 'Creer le role'}) }}
    </div>
  </div>
{% endblock %}

