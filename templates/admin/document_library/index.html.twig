{% extends 'admin/base.html.twig' %}

{% block title %}Bibliotheque documentaire - Administration - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Bibliotheque documentaire</h1>
  </div>
{% endblock %}

{% block content %}
  <style>
    .drive-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
    }

    .drive-folder {
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 0.85rem;
      padding: 0.75rem;
      background: rgba(248, 250, 252, 0.65);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem;
    }

    .drive-folder-title {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: #0f172a;
      text-decoration: none;
      min-width: 0;
      font-weight: 600;
      font-size: 0.83rem;
    }

    .drive-folder-title i {
      width: 1.2rem;
      height: 1.2rem;
    }

    .drive-folder-title span {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .drive-breadcrumb {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.45rem;
      font-size: 0.82rem;
      color: #64748b;
    }

    .drive-breadcrumb a {
      color: #475569;
      text-decoration: none;
    }

    .drive-breadcrumb a:hover {
      text-decoration: underline;
    }

    .drive-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.45);
      backdrop-filter: blur(2px);
      z-index: 90;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .drive-modal-overlay.is-open {
      display: flex;
    }

    .drive-modal {
      width: min(540px, 100%);
      border-radius: 0.95rem;
      border: 1px solid rgba(148, 163, 184, 0.24);
      background: #ffffff;
      color: #0f172a;
      box-shadow: 0 22px 55px -28px rgba(15, 23, 42, 0.55);
      padding: 1rem;
    }

    .drive-modal h3 {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
    }

    .drive-modal p {
      margin: 0.28rem 0 0;
      color: #64748b;
      font-size: 0.78rem;
    }
  </style>

  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-5">
    <div>
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-2">Bibliotheque documentaire</h1>
      <div class="drive-breadcrumb">
        <a href="{{ path('app_document_admin_index') }}">Racine</a>
        {% for breadcrumb in breadcrumbs %}
          <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
          <a href="{{ path('app_document_admin_index', {'folder': breadcrumb.id}) }}">{{ breadcrumb.name }}</a>
        {% endfor %}
      </div>
    </div>

    <div class="flex items-center gap-2 flex-wrap">
      {% if currentFolder %}
        <button type="button" class="btn btn-secondary js-open-modal" data-modal-id="modal-subfolder">
          <i data-lucide="folder-plus" class="w-5 h-5"></i>
          <span>Creer un sous-dossier</span>
        </button>
        <button type="button" class="btn btn-primary js-open-modal" data-modal-id="modal-file">
          <i data-lucide="file-plus-2" class="w-5 h-5"></i>
          <span>Ajouter un fichier</span>
        </button>
      {% else %}
        <button type="button" class="btn btn-primary js-open-modal" data-modal-id="modal-root-folder">
          <i data-lucide="folder-plus" class="w-5 h-5"></i>
          <span>Creer un dossier</span>
        </button>
      {% endif %}
    </div>
  </div>

  <div class="card-elevated p-5">
    <div class="mb-4">
      <p class="text-xs uppercase tracking-widest text-muted mb-2">Dossiers</p>
      {% if childFolders is empty %}
        <p class="text-sm text-muted">Aucun dossier pour le moment.</p>
      {% else %}
        <div class="drive-grid">
          {% for folder in childFolders %}
            <div class="drive-folder">
              <a href="{{ path('app_document_admin_index', {'folder': folder.id}) }}" class="drive-folder-title">
                <i data-lucide="folder" class="w-5 h-5 text-indigo-400"></i>
                <span>{{ folder.name }}</span>
              </a>
              <div class="flex items-center gap-2 shrink-0">
                <a href="{{ path('app_document_admin_index', {'folder': folder.id}) }}"
                   class="text-slate-400 hover:text-slate-300 inline-flex items-center"
                   title="Afficher"
                   aria-label="Afficher">
                  <i data-lucide="eye" class="w-4 h-4"></i>
                </a>
                {% if folder.parent is null and folder.isSecured %}
                  <span class="badge badge-warning">Securise</span>
                {% endif %}
                <form method="post"
                      action="{{ path('app_document_admin_folder_delete', {'id': folder.id}) }}"
                      onsubmit="return confirm('Supprimer ce dossier et son contenu ?');"
                      class="inline">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_folder' ~ folder.id) }}">
                  <input type="hidden" name="return_folder" value="{{ currentFolder ? currentFolder.id : '' }}">
                  <button type="submit"
                          class="text-red-400 hover:text-red-300 inline-flex items-center"
                          title="Supprimer"
                          aria-label="Supprimer">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </form>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if currentFolder %}
      <div class="mt-6">
        <p class="text-xs uppercase tracking-widest text-muted mb-2">Fichiers dans "{{ currentFolder.name }}"</p>
        {% if items is empty %}
          <p class="text-sm text-muted">Aucun fichier dans ce dossier.</p>
        {% else %}
          <div class="overflow-x-auto">
            <table class="data-table admin-table">
              <thead>
                <tr>
                  <th>Titre</th>
                  <th>Type</th>
                  <th>Source</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for item in items %}
                  <tr>
                    <td>
                      <p class="font-semibold text-text">{{ item.title }}</p>
                    </td>
                    <td class="text-xs text-muted">
                      {% if item.itemType == constant('App\\Entity\\DocumentItem::TYPE_VIDEO_LINK') %}
                        Video
                      {% elseif item.itemType == constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') %}
                        Fichier
                      {% else %}
                        Lien
                      {% endif %}
                    </td>
                    <td class="text-xs text-muted">
                      {% if item.itemType == constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') %}
                        {{ item.originalFilename ?: '-' }}
                      {% else %}
                        <a href="{{ item.externalUrl }}" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">
                          Ouvrir
                        </a>
                      {% endif %}
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        {% if item.itemType == constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') %}
                          <a href="{{ path('app_document_file_download', {'id': item.id}) }}"
                             target="_blank"
                             rel="noopener"
                             class="text-slate-400 hover:text-slate-300 inline-flex items-center"
                             title="Afficher"
                             aria-label="Afficher">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                          </a>
                        {% elseif item.externalUrl %}
                          <a href="{{ item.externalUrl }}"
                             target="_blank"
                             rel="noopener"
                             class="text-slate-400 hover:text-slate-300 inline-flex items-center"
                             title="Afficher"
                             aria-label="Afficher">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                          </a>
                        {% endif %}
                        <a href="{{ path('app_document_admin_item_edit', {'id': item.id}) }}"
                           class="text-xs font-medium text-indigo-400 hover:text-indigo-300">Modifier</a>
                        <form method="post"
                              action="{{ path('app_document_admin_item_delete', {'id': item.id}) }}"
                              onsubmit="return confirm('Supprimer ce fichier ?');"
                              class="inline">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete_item' ~ item.id) }}">
                          <input type="hidden" name="return_folder" value="{{ currentFolder.id }}">
                          <button type="submit"
                                  class="text-red-400 hover:text-red-300 inline-flex items-center"
                                  title="Supprimer"
                                  aria-label="Supprimer">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="drive-modal-overlay" id="modal-root-folder">
    <div class="drive-modal">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3>Nouveau dossier racine</h3>
          <p>Ce dossier apparaitra a la racine.</p>
        </div>
        <button type="button" class="btn-icon js-close-modal"><i data-lucide="x" class="w-4 h-4"></i></button>
      </div>
      <form method="post" action="{{ path('app_document_admin_index') }}" class="space-y-4">
        <input type="hidden" name="action" value="create_folder">
        <input type="hidden" name="parent_id" value="">
        <div>
          <label class="block text-sm font-medium text-text mb-1.5">Nom</label>
          <input type="text" name="name" required class="form-control" placeholder="Nom du dossier">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1.5">Role autorise</label>
          <select name="access_role" class="form-control js-select2" data-placeholder="Choisir un role">
            <option value="">Tous les roles</option>
            {% for role in roles %}
              <option value="{{ role.code }}">{{ role.label }}</option>
            {% endfor %}
          </select>
          <p class="mt-1 text-xs text-muted">Selectionnez un role pour restreindre l acces, ou laissez vide pour un dossier public.</p>
        </div>
        <div class="flex items-center gap-3 pt-1">
          <button type="submit" class="btn btn-primary">Creer</button>
          <button type="button" class="text-sm text-muted hover:text-text js-close-modal">Annuler</button>
        </div>
      </form>
    </div>
  </div>

  {% if currentFolder %}
    <div class="drive-modal-overlay" id="modal-subfolder">
      <div class="drive-modal">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3>Nouveau sous-dossier</h3>
            <p>Parent: {{ currentFolder.name }}</p>
          </div>
          <button type="button" class="btn-icon js-close-modal"><i data-lucide="x" class="w-4 h-4"></i></button>
        </div>
        <form method="post" action="{{ path('app_document_admin_index', {'folder': currentFolder.id}) }}" class="space-y-4">
          <input type="hidden" name="action" value="create_folder">
          <input type="hidden" name="parent_id" value="{{ currentFolder.id }}">
          <div>
            <label class="block text-sm font-medium text-text mb-1.5">Nom</label>
            <input type="text" name="name" required class="form-control" placeholder="Nom du sous-dossier">
          </div>
          <div class="flex items-center gap-3 pt-1">
            <button type="submit" class="btn btn-primary">Creer</button>
            <button type="button" class="text-sm text-muted hover:text-text js-close-modal">Annuler</button>
          </div>
        </form>
      </div>
    </div>

    <div class="drive-modal-overlay" id="modal-file">
      <div class="drive-modal">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3>Nouveau fichier</h3>
            <p>Dossier: {{ currentFolder.name }}</p>
          </div>
          <button type="button" class="btn-icon js-close-modal"><i data-lucide="x" class="w-4 h-4"></i></button>
        </div>
        <form method="post" action="{{ path('app_document_admin_index', {'folder': currentFolder.id}) }}" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="action" value="create_item">
          <input type="hidden" name="folder_id" value="{{ currentFolder.id }}">
          <div>
            <label class="block text-sm font-medium text-text mb-1.5">Titre</label>
            <input type="text" name="title" required class="form-control" placeholder="Titre du fichier">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1.5">Type</label>
            <select name="item_type" class="form-control" data-role="item-type">
              <option value="{{ constant('App\\Entity\\DocumentItem::TYPE_VIDEO_LINK') }}">Lien video (YouTube/Vimeo)</option>
              <option value="{{ constant('App\\Entity\\DocumentItem::TYPE_EXTERNAL_LINK') }}">Lien externe</option>
              <option value="{{ constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') }}">Fichier (PDF, image, autre)</option>
            </select>
          </div>
          <div data-role="item-url">
            <label class="block text-sm font-medium text-text mb-1.5">URL</label>
            <input type="url" name="external_url" class="form-control" placeholder="https://...">
          </div>
          <div data-role="item-upload" style="display:none;">
            <label class="block text-sm font-medium text-text mb-1.5">Fichier</label>
            <input type="file" name="uploaded_file" class="form-control">
          </div>
          <div class="flex items-center gap-3 pt-1">
            <button type="submit" class="btn btn-primary">Ajouter</button>
            <button type="button" class="text-sm text-muted hover:text-text js-close-modal">Annuler</button>
          </div>
        </form>
      </div>
    </div>
  {% endif %}

  <script>
    (function () {
      const openButtons = document.querySelectorAll('.js-open-modal');
      const closeButtons = document.querySelectorAll('.js-close-modal');

      const closeAll = () => {
        document.querySelectorAll('.drive-modal-overlay.is-open').forEach((modal) => {
          modal.classList.remove('is-open');
        });
      };

      openButtons.forEach((button) => {
        button.addEventListener('click', () => {
          closeAll();
          const modalId = button.getAttribute('data-modal-id');
          const modal = document.getElementById(modalId);
          if (modal) {
            modal.classList.add('is-open');
          }
        });
      });

      closeButtons.forEach((button) => {
        button.addEventListener('click', closeAll);
      });

      document.querySelectorAll('.drive-modal-overlay').forEach((modal) => {
        modal.addEventListener('click', (event) => {
          if (event.target === modal) {
            closeAll();
          }
        });
      });

      const itemTypeField = document.querySelector('[data-role="item-type"]');
      const itemUrlWrapper = document.querySelector('[data-role="item-url"]');
      const itemUploadWrapper = document.querySelector('[data-role="item-upload"]');
      if (itemTypeField && itemUrlWrapper && itemUploadWrapper) {
        const syncItemType = () => {
          const isUpload = itemTypeField.value === '{{ constant('App\\Entity\\DocumentItem::TYPE_UPLOADED_FILE') }}';
          itemUrlWrapper.style.display = isUpload ? 'none' : '';
          itemUploadWrapper.style.display = isUpload ? '' : 'none';
        };
        itemTypeField.addEventListener('change', syncItemType);
        syncItemType();
      }
    })();
  </script>
{% endblock %}
