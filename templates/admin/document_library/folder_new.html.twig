{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau dossier - Administration - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Nouveau dossier</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-text">Creer un dossier</h1>
    <p class="text-muted mt-1">Les sous-dossiers et fichiers pourront etre ajoutes ensuite.</p>
  </div>

  <div class="card-elevated p-6">
    {{ include('admin/document_library/_folder_form.html.twig', {rootRoleSelectMode: rootRoleSelectMode|default(false)}) }}
  </div>
{% endblock %}
