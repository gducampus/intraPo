{% extends 'admin/base.html.twig' %}

{% block title %}Catalogue des fonctionnalites - Administration - Intranet PO{% endblock %}

{% block page_header %}
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-muted">Administration</p>
    <h1 class="text-sm font-semibold text-text">Catalogue des fonctionnalites</h1>
  </div>
{% endblock %}

{% block content %}
  <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-2">Catalogue des fonctionnalites</h1>
      <p class="text-muted">Routes applicatives assignables aux modules metier.</p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <form method="post" action="{{ path('app_feature_sync') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('sync_catalog') }}">
        <button type="submit" class="btn btn-secondary">
          <i data-lucide="refresh-cw" class="w-4 h-4"></i>
          <span>Synchroniser les routes</span>
        </button>
      </form>
      <a href="{{ path('app_feature_new') }}" class="btn btn-primary">
        <i data-lucide="plus" class="w-4 h-4"></i>
        <span>Nouvelle fonctionnalite</span>
      </a>
    </div>
  </div>

  <div class="mb-5 rounded-xl border border-indigo-500/20 bg-indigo-500/10 px-4 py-3 text-sm text-indigo-300">
    Synchronisation auto active: les nouvelles routes applicatives GET (index, creation, edition, etc.) sont ajoutees au catalogue.
    {% if syncedCount > 0 %}
      <span class="font-semibold text-indigo-200"> {{ syncedCount }} nouveaute(s) detectee(s).</span>
    {% endif %}
  </div>

  <div class="card-elevated">
    <div class="overflow-x-auto">
      <table class="data-table admin-table">
        <thead>
          <tr>
            <th>Libelle</th>
            <th>Categorie</th>
            <th>Route / URL</th>
            <th>Icone</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for feature in features %}
            <tr>
              <td>
                <div class="flex items-center gap-2">
                  {% if feature.icon %}
                    <i data-lucide="{{ feature.icon }}" class="w-4 h-4 text-muted shrink-0"></i>
                  {% endif %}
                  <span class="font-semibold text-text">{{ feature.label }}</span>
                </div>
                {% if feature.description %}
                  <p class="text-xs text-muted mt-1 max-w-md">{{ feature.description }}</p>
                {% endif %}
              </td>
              <td>
                {% if feature.category %}
                  <span class="badge badge-info">{{ feature.category }}</span>
                {% else %}
                  <span class="text-muted text-xs">-</span>
                {% endif %}
              </td>
              <td class="text-xs font-mono">
                {% if feature.routeName %}
                  <span class="badge badge-success">{{ feature.routeName }}</span>
                {% elseif feature.url %}
                  <span class="text-muted">{{ feature.url }}</span>
                {% else %}
                  <span class="text-muted">-</span>
                {% endif %}
              </td>
              <td class="text-xs font-mono text-muted">{{ feature.icon ?? '-' }}</td>
              <td>
                <div class="flex items-center gap-3">
                  <a href="{{ path('app_feature_edit', {'id': feature.id}) }}"
                     class="text-sm font-medium text-indigo-400 hover:text-indigo-300">Modifier</a>
                  <form method="post" action="{{ path('app_feature_delete', {'id': feature.id}) }}"
                        onsubmit="return confirm('Supprimer \"{{ feature.label }}\" du catalogue ?');"
                        class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ feature.id) }}">
                    <button type="submit" class="text-sm font-medium text-red-400 hover:text-red-300">Supprimer</button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5" class="text-center text-muted py-12">
                Aucune fonctionnalite dans le catalogue.
                <a href="{{ path('app_feature_new') }}" class="ml-1 font-medium text-indigo-400 underline">Creer la premiere</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
